generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Seller {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  companyName      String
  contactName      String
  phone            String
  paypalMe         String?
  stripeCustomerId String?
  verified         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  products         Product[]
  reviewsReceived  Review[]
  emailVerified    Boolean   @default(false)
  verifyToken      String?
  resetTokenExpiry DateTime?
  avasam           Boolean   @default(false)
  trialEndsAt      DateTime?
  trialEmailDay25  Boolean   @default(false)
  trialEmailDay30  Boolean   @default(false)
  orders           Order[]
}

model Buyer {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String
  name             String
  createdAt        DateTime @default(now())
  emailVerified    Boolean  @default(false)
  verifyToken      String?
  resetTokenExpiry DateTime?
}

model Product {
  id                 String    @id @default(cuid())
  sellerId           String
  title              String
  description        String
  price              Float
  photos             String    @default("[]")
  category           String?
  deliveryTime       String?
  active             Boolean   @default(false)
  featured           Boolean   @default(false)
  featuredSubId      String?
  stripeSubId        String?
  subscriptionEndsAt DateTime?
  slug               String?   @unique
  sku                String?
  views              Int       @default(0)
  createdAt          DateTime  @default(now())
  seller             Seller    @relation(fields: [sellerId], references: [id])
  reviews            Review[]
  orderItems         OrderItem[]
}

model Favourite {
  id         String   @id @default(cuid())
  buyerEmail String
  productId  String
  createdAt  DateTime @default(now())

  @@unique([buyerEmail, productId])
}

model Report {
  id        String   @id @default(cuid())
  productId String
  reason    String
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  productId String
  sellerId  String
  buyerName String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
}

model Order {
  id              String      @id @default(cuid())
  sellerId        String
  externalOrderId String?     @unique
  buyerName       String
  buyerEmail      String
  buyerPhone      String?
  shippingLine1   String
  shippingLine2   String?
  shippingCity    String
  shippingPostcode String
  shippingCountry String      @default("GB")
  status          String      @default("pending")
  trackingNumber  String?
  carrier         String?
  dispatchedAt    DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  seller          Seller      @relation(fields: [sellerId], references: [id])
  items           OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  sku       String?
  title     String
  price     Float
  quantity  Int     @default(1)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}
